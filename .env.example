# Telegram Bot Token (BotFather'dan olingan)
BOT_TOKEN=your_bot_token_here

# Admin Telegram ID lar (vergul bilan ajratilgan)
ADMIN_IDS=1054482233

# Koordinatorlar — har filial alohida (ajratilgan)
# Format: branch:telegram_id,telegram_id;branch:telegram_id
# Masalan: integro:5238121241,1054482233;amir_temur:87654321;xalqlas:111111;online:222222
# Eski COORDINATOR_IDS formati ham ishlaydi (hamma filialni ko'radi)
COORDINATORS=integro:5238121241;amir_temur:;xalqlas:;online:

# Guruh ID si
GROUP_ID=-1003981182641

# Google Sheets
SHEET_KEY=your_google_sheet_key
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
